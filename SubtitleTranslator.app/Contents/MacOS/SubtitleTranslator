#!/bin/bash
# Launcher for Subtitle Translator.
# Resolves repo root from .app location, bootstraps the venv, then runs setup_gui.py.
set -e

# .app is at <repo>/SubtitleTranslator.app — repo root is one level up
REPO="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$REPO"

VENV="$REPO/.venv"
PYTHON="$VENV/bin/python"
PIP="$VENV/bin/pip"

# ── 1. Create virtualenv if it doesn't exist ─────────────────────────────────
if [ ! -f "$PYTHON" ]; then
    python3 -m venv "$VENV"
fi

# ── 2. Install PySide6 (needed to show the setup GUI) ────────────────────────
#    Show a tkinter splash while pip runs so the user knows something is happening.
if ! "$PYTHON" -c "import PySide6" 2>/dev/null; then
    python3 "$REPO/bootstrap.py" &
    BOOTSTRAP_PID=$!
    "$PIP" install --quiet "PySide6>=6.6.0"
    kill "$BOOTSTRAP_PID" 2>/dev/null || true
fi

# ── 3. Hand off to the PySide6 setup/launcher GUI ────────────────────────────
exec "$PYTHON" "$REPO/setup_gui.py"
